{
	"name": "@predictor-foundation/graphql-client",
	"version": "0.1.0",
	"description": "Framework-light GraphQL-over-HTTP client for Predictor Foundation frontends: fetchGraphql, fragment registry, Relay connection to page mapping, a non-fatal error hierarchy, and an optional SWR/React data-fetch layer",
	"license": "UNLICENSED",
	"private": false,
	"publishConfig": {
		"registry": "https://npm.pkg.github.com"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Predictor-Foundation/predictor-common.git",
		"directory": "packages/web/graphql-client"
	},
	"main": "lib/index.js",
	"types": "lib/index.d.ts",
	"exports": {
		".": {
			"types": "./lib/index.d.ts",
			"default": "./lib/index.js"
		},
		"./react": {
			"types": "./lib/react/index.d.ts",
			"default": "./lib/react/index.js"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"lib/",
		"README.md"
	],
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"build": "rm -rf lib *.tsbuildinfo && tsc",
		"typecheck": "tsc --noEmit",
		"clean": "rm -rf lib *.tsbuildinfo"
	},
	"dependencies": {
		"ts-custom-error": "^3.3.1"
	},
	"peerDependencies": {
		"react": "^18.0.0 || ^19.0.0",
		"swr": "^2.0.0"
	},
	"peerDependenciesMeta": {
		"react": {
			"optional": true
		},
		"swr": {
			"optional": true
		}
	},
	"devDependencies": {
		"@types/node": "^22.0.0",
		"@types/react": "^18.2.0",
		"react": "^18.2.0",
		"swr": "^2.2.4",
		"typescript": "^5.6.0"
	}
}
