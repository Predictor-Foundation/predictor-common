{
	"name": "@predictor-foundation/e2e",
	"version": "0.1.0",
	"description": "Zero-setup Playwright E2E harness (config factory, server orchestration, re-exported test API) for the Predictor Foundation",
	"license": "UNLICENSED",
	"private": false,
	"type": "module",
	"publishConfig": {
		"registry": "https://npm.pkg.github.com"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Predictor-Foundation/predictor-common.git",
		"directory": "packages/e2e"
	},
	"main": "lib/index.js",
	"types": "lib/index.d.ts",
	"exports": {
		".": {
			"types": "./lib/index.d.ts",
			"default": "./lib/index.js"
		}
	},
	"files": [
		"lib/",
		"README.md"
	],
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"build": "rm -rf lib *.tsbuildinfo && tsc",
		"types:check": "tsc --noEmit",
		"clean": "rm -rf lib *.tsbuildinfo"
	},
	"peerDependencies": {
		"@playwright/test": ">=1.40.0"
	},
	"devDependencies": {
		"@playwright/test": "^1.49.0",
		"@types/node": "^22.0.0",
		"typescript": "^5.6.0"
	}
}
