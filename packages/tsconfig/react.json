{
	"$schema": "https://json.schemastore.org/tsconfig",
	"display": "@predictor-foundation/tsconfig/react",
	"extends": "./base.json",
	"compilerOptions": {
		"lib": ["DOM", "DOM.Iterable", "ES2022"],
		"jsx": "react-jsx",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"noEmit": true,
		"isolatedModules": true
	}
}
