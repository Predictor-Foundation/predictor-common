{
	"name": "@predictor-foundation/logger",
	"version": "0.1.2",
	"description": "Tiny dependency-free structured JSON-lines logger (level-filtered, stdout/stderr split) for the Predictor Foundation services",
	"license": "UNLICENSED",
	"private": false,
	"publishConfig": {
		"registry": "https://npm.pkg.github.com"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Predictor-Foundation/predictor-common.git",
		"directory": "packages/service/logger"
	},
	"main": "lib/index.js",
	"types": "lib/index.d.ts",
	"files": [
		"lib/",
		"README.md"
	],
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"build": "rm -rf lib *.tsbuildinfo && tsc",
		"typecheck": "tsc --noEmit",
		"test": "node --experimental-strip-types --test 'test/*.test.ts'",
		"clean": "rm -rf lib *.tsbuildinfo"
	},
	"devDependencies": {
		"@types/node": "catalog:",
		"typescript": "catalog:"
	}
}
