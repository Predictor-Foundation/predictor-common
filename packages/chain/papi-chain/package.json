{
	"name": "@predictor-foundation/papi-chain",
	"version": "0.1.1",
	"description": "Descriptor-generic polkadot-api chain boundary (connect, timed reads, signed/unsigned submit) for the Predictor Foundation services",
	"license": "UNLICENSED",
	"private": false,
	"type": "module",
	"publishConfig": {
		"registry": "https://npm.pkg.github.com"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Predictor-Foundation/predictor-common.git",
		"directory": "packages/chain/papi-chain"
	},
	"main": "lib/index.js",
	"types": "lib/index.d.ts",
	"exports": {
		".": {
			"types": "./lib/index.d.ts",
			"default": "./lib/index.js"
		}
	},
	"files": [
		"lib/",
		"README.md"
	],
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"build": "rm -rf lib *.tsbuildinfo && tsc",
		"test": "node --experimental-strip-types --test 'test/*.test.ts'",
		"types:check": "tsc --noEmit",
		"clean": "rm -rf lib *.tsbuildinfo"
	},
	"dependencies": {
		"@predictor-foundation/chain-errors": "workspace:*"
	},
	"peerDependencies": {
		"polkadot-api": "^2.1.7"
	},
	"devDependencies": {
		"@types/node": "^22.0.0",
		"polkadot-api": "^2.1.7",
		"typescript": "^5.6.0"
	}
}
