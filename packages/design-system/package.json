{
	"name": "@predictor-foundation/design-system",
	"version": "0.1.0",
	"description": "Shared PRDCTR Material-UI theme + design tokens for the Predictor Foundation frontends",
	"license": "UNLICENSED",
	"private": false,
	"type": "module",
	"publishConfig": {
		"registry": "https://npm.pkg.github.com"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Predictor-Foundation/predictor-common.git",
		"directory": "packages/design-system"
	},
	"main": "lib/index.js",
	"types": "lib/index.d.ts",
	"exports": {
		".": {
			"types": "./lib/index.d.ts",
			"default": "./lib/index.js"
		},
		"./styles.css": "./styles.css"
	},
	"files": [
		"lib/",
		"styles.css",
		"README.md"
	],
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"build": "rm -rf lib *.tsbuildinfo && tsc",
		"types:check": "tsc --noEmit",
		"clean": "rm -rf lib *.tsbuildinfo"
	},
	"peerDependencies": {
		"@emotion/react": "^11.10.0",
		"@emotion/styled": "^11.10.0",
		"@mui/material": "^5.11.0",
		"react": "^18.0.0 || ^19.0.0"
	},
	"devDependencies": {
		"@emotion/react": "^11.10.6",
		"@emotion/styled": "^11.10.6",
		"@mui/material": "^5.11.14",
		"@types/react": "^18.2.0",
		"react": "^18.2.0",
		"typescript": "^5.6.0"
	}
}
