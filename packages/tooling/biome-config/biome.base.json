{
	"$schema": "https://biomejs.dev/schemas/2.3.14/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"includes": [
			"**",
			"!**/node_modules",
			"!**/lib",
			"!**/dist",
			"!**/*.generated.*",
			"!**/generated",
			"!**/pnpm-lock.yaml"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"semicolons": "always"
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"correctness": {
				"noUnusedVariables": "warn",
				"noConstantCondition": "warn",
				"noUnusedImports": "warn",
				"noUnsafeOptionalChaining": "warn"
			},
			"suspicious": {
				"noDebugger": "warn",
				"noEmptyInterface": "off",
				"noEmptyBlockStatements": "off",
				"noExplicitAny": "off",
				"noArrayIndexKey": "warn",
				"noControlCharactersInRegex": "warn",
				"useIterableCallbackReturn": "warn"
			},
			"style": {
				"useConst": "warn",
				"useImportType": "off",
				"useNodejsImportProtocol": "off",
				"noNonNullAssertion": "warn"
			},
			"complexity": {
				"noBannedTypes": "warn",
				"noStaticOnlyClass": "warn"
			}
		}
	}
}
